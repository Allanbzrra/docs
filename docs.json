{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mapa do Saber",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {"group": "Primeiros passos", "pages": ["index", "quickstart", "development"]},
          {"group": "Personalização", "pages": ["essentials/settings", "essentials/navigation"]},
          {"group": "Redação de conteúdo", "pages": ["essentials/markdown", "essentials/code", "essentials/images", "essentials/reusable-snippets"]},
          {"group": "Ferramentas de IA", "pages": ["ai-tools/cursor", "ai-tools/claude-code", "ai-tools/windsurf"]}
        ]
      },
      {
        "tab": "Referência da API",
        "groups": [
          {"group": "Documentação da API", "pages": ["api-reference/introduction"]},
          {"group": "Exemplos de endpoints", "pages": ["api-reference/endpoint/get", "api-reference/endpoint/create", "api-reference/endpoint/delete", "api-reference/endpoint/webhook"]}
        ]
      }
    ]
  },
  "global": {
    "anchors": [
      {"anchor": "App", "href": "https://app.mapadosaber.com.br", "icon": "mobile"},
      {"anchor": "Web", "href": "https://www.mapadosaber.com.br", "icon": "globe"}
    ]
  },
  "logo": {"light": "/logo/light.svg", "dark": "/logo/dark.svg"},
  "navbar": {
    "links": [
      {"label": "App", "href": "https://app.mapadosaber.com.br"},
      {"label": "Web", "href": "https://www.mapadosaber.com.br"},
      {"label": "Contato", "href": "mailto:contato@mapadosaber.com.br"}
    ],
    "primary": {"type": "button", "label": "Acessar App", "href": "https://app.mapadosaber.com.br"}
  },
  "contextual": {"options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]},
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/somosmapadosaber"
    }
  }
}
